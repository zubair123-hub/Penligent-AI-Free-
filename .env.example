# Penligent AI Configuration

# AI/LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
LLM_PROVIDER=openai  # Options: openai, local, huggingface

# Local LLM (for offline use)
LOCAL_LLM_MODEL=mistral-7b
LOCAL_LLM_ENDPOINT=http://localhost:8000

# Database
DATABASE_URL=sqlite:///./penligent.db
# DATABASE_URL=postgresql://user:password@localhost/penligent

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/penligent.log

# Scanning Configuration
MAX_THREADS=10
TIMEOUT=30
RETRY_COUNT=3

# Network Scanning
ENABLE_NMAP=true
NMAP_PATH=/usr/bin/nmap

# API Server (optional)
API_HOST=0.0.0.0
API_PORT=8080
API_DEBUG=false

# Output
OUTPUT_FORMAT=json  # Options: json, csv, txt
REPORTS_DIR=./reports
